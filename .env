# In all environments, the following files are loaded if they exist,
# the latter taking precedence over the former:
#
#  * .env                contains default values for the environment variables needed by the app
#  * .env.local          uncommitted file with local overrides
#  * .env.$APP_ENV       committed environment-specific defaults
#  * .env.$APP_ENV.local uncommitted environment-specific overrides
#
# Real environment variables win over .env files.
#
# DO NOT DEFINE PRODUCTION SECRETS IN THIS FILE NOR IN ANY OTHER COMMITTED FILES.
# https://symfony.com/doc/current/configuration/secrets.html
#
# Run "composer dump-env prod" to compile .env files for production use (requires symfony/flex >=1.2).
# https://symfony.com/doc/current/best_practices.html#use-environment-variables-for-infrastructure-configuration

###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=
###< symfony/framework-bundle ###

###> symfony/routing ###
# Configure how to generate URLs in non-HTTP contexts, such as CLI commands.
# See https://symfony.com/doc/current/routing.html#generating-urls-in-commands
DEFAULT_URI=http://localhost
###< symfony/routing ###

###> spotify ###
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=https://your-host/spotify/callback
###< spotify ###

###> sonos ###
SONOS_IP=
SONOS_CLIENT_ID=
SONOS_CLIENT_SECRET=
SONOS_REDIRECT_URI=https://your-host/sonos/callback
###< sonos ###

###> spotify-device ###
SPOTIFY_DEVICE_NAME=PHPSD
SONOS_SPOTIFY_SN=0
###< spotify-device ###

###> groq ###
GROQ_API_KEY=your-groq-api-key
###< groq ###

###> dj-tts ###
# HTTP base URL reachable by the Sonos speaker on the LAN (port 8080 serves /sounds/)
DJ_SERVER_URL=http://127.0.0.1:8080
# Language for DJ announcements: en or nl
DJ_LANGUAGE=en
# TTS provider: "elevenlabs", "piper", or "edge" (default: edge)
DJ_TTS_PROVIDER=edge
# ElevenLabs API key + voice ID — only used when DJ_TTS_PROVIDER=elevenlabs
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
# Piper TTS model (path relative to project root). Only used when DJ_TTS_PROVIDER=piper.
DJ_PIPER_MODEL=var/piper/en_US-ryan-high.onnx
# edge-tts voice — only used when DJ_TTS_PROVIDER=edge. Run "bin/console radio:dj-voices" to list options.
DJ_VOICE=en-US-GuyNeural
# Background music bed mixed under DJ voice (path relative to project root, leave empty to disable)
DJ_BED_FILE=public/sounds/fillers/dj-bed.mp3
# Bed volume 0.0–1.0
DJ_BED_VOLUME=0.20
# IP of the device to play DJ clips on via DLNA/UPnP (e.g. Samsung soundbar). Leave empty to play via browser.
DJ_CLIP_IP=192.168.2.4
###< dj-tts ###

###> jira-monitor ###
JIRA_HOST=https://your-company.atlassian.net
JIRA_USER=your-email@srs.nl
JIRA_TOKEN=your-api-token
JIRA_ALARM_ACCOUNT=Support
JIRA_ALARM_LABELS=
JIRA_ALARM_CLIP_URL=http://127.0.0.1:8080/sounds/air_raid_siren.mp3
###< jira-monitor ###

###> weather ###
WEATHER_API_KEY=
WEATHER_LOCATION=Amsterdam,NL
WEATHER_HOUR=12
WEATHER_MINUTE=20
###< weather ###

###> news ###
NEWS_FEED_URL=https://www.nu.nl/rss
###< news ###

###> doctrine/doctrine-bundle ###
# Format described at https://www.doctrine-project.org/projects/doctrine-dbal/en/latest/reference/configuration.html#connecting-using-a-url
# IMPORTANT: You MUST configure your server version, either here or in config/packages/doctrine.yaml
#
# DATABASE_URL="sqlite:///%kernel.project_dir%/var/data_%kernel.environment%.db"
# DATABASE_URL="mysql://app:!ChangeMe!@127.0.0.1:3306/app?serverVersion=10.11.2-MariaDB&charset=utf8mb4"
DATABASE_URL="mysql://app:!ChangeMe!@127.0.0.1:3306/app?serverVersion=8.0.32&charset=utf8mb4"
###< doctrine/doctrine-bundle ###
