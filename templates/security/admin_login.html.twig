<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SRS Radio – Admin sign in</title>
    <link href="https://fonts.googleapis.com/css2?family=Raleway:wght@300;400;700;900&family=Lato:wght@300;400;700&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

        html, body {
            height: 100%;
            font-family: 'Lato', sans-serif;
            background: #0d0d1a;
            color: #fff;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .card {
            background: #14142b;
            border: 1px solid #2a2a4a;
            border-radius: 12px;
            padding: 2.5rem 2.75rem;
            width: 100%;
            max-width: 400px;
            box-shadow: 0 20px 60px rgba(0,0,0,.6);
        }

        .badge {
            display: inline-block;
            background: rgba(180,120,255,.15);
            border: 1px solid rgba(180,120,255,.3);
            border-radius: 20px;
            padding: .25rem .75rem;
            font-size: .7rem;
            font-weight: 700;
            letter-spacing: .12em;
            text-transform: uppercase;
            color: #b47fff;
            margin-bottom: 1rem;
        }

        .logo-wrap {
            text-align: center;
            margin-bottom: 1.75rem;
        }

        .logo-icon {
            font-size: 2.5rem;
            display: block;
            margin-bottom: .5rem;
        }

        h1 {
            font-family: 'Raleway', sans-serif;
            font-size: 1.5rem;
            font-weight: 700;
            letter-spacing: .1em;
            text-align: center;
            color: #b47fff;
        }

        .subtitle {
            text-align: center;
            font-size: .85rem;
            color: #6b5a8a;
            margin-top: .25rem;
        }

        .error-box {
            background: rgba(239,68,68,.15);
            border: 1px solid rgba(239,68,68,.4);
            border-radius: 6px;
            padding: .75rem 1rem;
            margin: 1.25rem 0 0;
            font-size: .875rem;
            color: #fca5a5;
        }

        .form-group {
            margin-top: 1.25rem;
        }

        label {
            display: block;
            font-size: .8rem;
            font-weight: 700;
            letter-spacing: .08em;
            text-transform: uppercase;
            color: #6b5a8a;
            margin-bottom: .4rem;
        }

        input[type="email"],
        input[type="text"],
        input[type="password"] {
            width: 100%;
            background: #0a0a1a;
            border: 1px solid #2a2a4a;
            border-radius: 6px;
            padding: .65rem .9rem;
            color: #fff;
            font-size: .95rem;
            font-family: 'Lato', sans-serif;
            transition: border-color .2s;
            outline: none;
        }

        input:focus {
            border-color: #7c3aed;
        }

        .remember {
            display: flex;
            align-items: center;
            gap: .5rem;
            margin-top: 1rem;
            font-size: .85rem;
            color: #6b5a8a;
            cursor: pointer;
        }

        .remember input { width: auto; }

        .btn {
            width: 100%;
            margin-top: 1.5rem;
            padding: .75rem;
            background: #5b21b6;
            border: none;
            border-radius: 6px;
            color: #fff;
            font-family: 'Raleway', sans-serif;
            font-size: 1rem;
            font-weight: 700;
            letter-spacing: .08em;
            cursor: pointer;
            transition: background .2s;
        }

        .btn:hover { background: #6d28d9; }

        .user-link {
            text-align: center;
            margin-top: 1.5rem;
            font-size: .8rem;
            color: #3a2a5a;
        }

        .user-link a {
            color: #3a2a5a;
            text-decoration: none;
            border-bottom: 1px solid #3a2a5a;
            transition: color .2s;
        }

        .user-link a:hover { color: #b47fff; }
    </style>
</head>
<body>
    <div class="card">
        <div class="logo-wrap">
            <span class="logo-icon">🛡️</span>
            <div style="text-align:center;margin-bottom:.5rem">
                <span class="badge">Administrator</span>
            </div>
            <h1>SRS RADIO</h1>
            <p class="subtitle">Admin area – restricted access</p>
        </div>

        {% if error %}
            <div class="error-box">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
        {% endif %}

        <form method="post">
            <div class="form-group">
                <label for="username">Email address</label>
                <input type="email" id="username" name="_username"
                       value="{{ last_username }}" autocomplete="email" required autofocus>
            </div>

            <div class="form-group">
                <label for="password">Password</label>
                <input type="password" id="password" name="_password" autocomplete="current-password" required>
            </div>

            <label class="remember">
                <input type="checkbox" name="_remember_me"> Remember me
            </label>

            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

            <button type="submit" class="btn">Sign in as admin</button>
        </form>

        <p class="user-link">
            Not an admin? <a href="{{ path('app_login') }}">Go to user login</a>
        </p>
    </div>
</body>
</html>
